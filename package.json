  "description": "A simple CLI dungeon-like game using TypeScript",
  "main": "build/index.js",
  "scripts": {
    "build": "tsc",
    "start": "ts-node src/index.ts",
    "prettier": "prettier --write \"src/**/*.ts\"",
    "# https://github.com/nodejs/node/issues/60704#issuecomment-3529614006": "",
