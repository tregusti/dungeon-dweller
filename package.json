    "test:watch": "NODE_OPTIONS='--no-experimental-webstorage' jest --watch"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.4.0",
    "@types/seedrandom": "^3.0.8",
    "expect-type": "^1.3.0",
    "jest": "^30.3.0",
    "prettier": "^3.8.1",
    "prettier-plugin-jsdoc": "^1.8.0",
    "ts-essentials": "^10.1.1",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2"
  },
  "dependencies": {
    "seedrandom": "^3.0.5"
  }
