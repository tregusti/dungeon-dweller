root = true

# How prettier uses this config.
# https://prettier.io/docs/api.html#prettierresolveconfigfileurlorpath--options

[*]
charset = utf-8
max_line_length = 100
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
max_line_length = 80
trim_trailing_whitespace = false
